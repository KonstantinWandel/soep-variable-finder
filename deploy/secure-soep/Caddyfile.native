{
  admin off
  auto_https off
}

http://127.0.0.1:15181

encode gzip zstd

header {
  X-Content-Type-Options "nosniff"
  X-Frame-Options "DENY"
  Referrer-Policy "strict-origin-when-cross-origin"
}

handle /api/* {
  reverse_proxy 127.0.0.1:18001
}

handle {
  root * /home/researcher/kwandel/destatis-rag/frontend/dist-soep
  try_files {path} /index.html
  file_server
}
